{
  "name": "@iwasa-kosui/blog",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm build:client && pnpm build:server && pnpm build:ssg && pnpm build:og",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:ssg": "tsx scripts/build-ssg.ts",
    "build:og": "tsx scripts/generate-og.ts",
    "preview": "npx serve dist"
  },
  "dependencies": {
    "@iwasa-kosui/ui": "workspace:*",
    "@mdx-js/react": "^3.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.6.3"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "glob": "^11.0.2",
    "rehype-pretty-code": "^0.14.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.0.0",
    "satori": "^0.12.2",
    "shiki": "^3.7.0",
    "shadcn": "3.8.5",
    "tailwindcss": "4.2.0",
    "tw-animate-css": "1.4.0",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.0-beta.13"
  }
}
