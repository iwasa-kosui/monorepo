---
import BookLayout from '@/layouts/BookLayout.astro';
import { type CollectionEntry, getCollection, render } from 'astro:content';

type BookEntry = CollectionEntry<'books'>;
type ChapterEntry = CollectionEntry<'bookChapters'>;

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book: BookEntry) => ({
    params: { book: book.data.bookSlug },
    props: { book },
  }));
}

const { book } = Astro.props as { book: BookEntry };
const { Content } = await render(book);

const allChapters = await getCollection('bookChapters');
const chapters: ChapterEntry[] = allChapters
  .filter((c: ChapterEntry) => c.data.bookSlug === book.data.bookSlug)
  .sort(
    (a: ChapterEntry, b: ChapterEntry) => a.data.order - b.data.order,
  );

const pageUrl = `https://kosui.me/books/${book.data.bookSlug}`;
const ogTitle = book.data.subtitle
  ? `${book.data.title}: ${book.data.subtitle}`
  : book.data.title;

function chapterLabel(order: number): string {
  if (order === 99) return '最終章';
  return `第${order}章`;
}
---

<BookLayout
  bookSlug={book.data.bookSlug}
  bookTitle={book.data.title}
  ogTitle={ogTitle}
  ogDescription={book.data.description}
  ogUrl={pageUrl}
  noindex={book.data.draft === true}
>
  <article class="article-paper">
    <header class="mb-8">
      <p class="text-sm text-accent dark:text-accent-light">
        {book.data.seriesTitle}
      </p>
      <h1 class="text-3xl font-bold mt-2 mb-2">
        {book.data.title}
      </h1>
      {
        book.data.subtitle && (
          <p class="text-base text-subtle dark:text-[#9ca3af]">
            {book.data.subtitle}
          </p>
        )
      }
      {
        book.data.draft && (
          <p class="mt-3 text-xs text-amber-700 dark:text-amber-300">
            執筆中
          </p>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
    <section class="mt-10">
      <h2 class="text-lg font-semibold mb-4 text-charcoal dark:text-gray-100">
        目次
      </h2>
      <ol class="space-y-3">
        {
          chapters.map((chapter: ChapterEntry) => (
            <li class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-4 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover relative">
              <p class="text-xs text-subtle dark:text-[#9ca3af]">
                {chapterLabel(chapter.data.order)}
                {chapter.data.draft ? ' · 執筆中' : ''}
              </p>
              <h3 class="text-base font-semibold mt-1 text-charcoal dark:text-gray-100">
                <a
                  href={`/books/${book.data.bookSlug}/${chapter.data.chapterSlug}`}
                  class="card-link-overlay"
                >
                  {chapter.data.title}
                </a>
              </h3>
              {
                chapter.data.summary && (
                  <p class="mt-2 text-sm text-subtle dark:text-[#9ca3af]">
                    {chapter.data.summary}
                  </p>
                )
              }
            </li>
          ))
        }
      </ol>
    </section>
  </article>
</BookLayout>
