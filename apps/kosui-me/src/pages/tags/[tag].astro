---
const themeMap: Record<string, string> = {
  TypeScript: 'typescript',
  アーキテクチャ: 'architecture',
  SRE: 'sre',
  チームプラクティス: 'team',
};

export function getStaticPaths() {
  const themeMap: Record<string, string> = {
    TypeScript: 'typescript',
    アーキテクチャ: 'architecture',
    SRE: 'sre',
    チームプラクティス: 'team',
  };
  return Object.keys(themeMap).map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;
const themeSlug = themeMap[tag!];

if (themeSlug) {
  return Astro.redirect(`/themes/${themeSlug}`, 301);
}

return new Response(null, { status: 404 });
---
