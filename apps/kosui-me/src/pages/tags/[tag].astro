---
import TagBadge from '@/components/TagBadge.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import externalArticlesData from '../../content/external-articles/data.json';
import talksData from '../../content/talks/data.json';

type TalkMeta = {
  title: string;
  date: string;
  event: string;
  tags: string[];
  duration: string;
  description: string;
  year: string;
  name: string;
  slideType: string;
};

type ExternalArticleMeta = {
  title: string;
  url: string;
  date: string;
  publisher: string;
  description?: string;
  tags: string[];
};

type TimelineItem =
  | {
    kind: 'post';
    date: string;
    data: {
      title: string;
      slug: string;
      description?: string;
      tags?: string[];
    };
  }
  | { kind: 'talk'; date: string; data: TalkMeta }
  | { kind: 'external-article'; date: string; data: ExternalArticleMeta };

export async function getStaticPaths() {
  const posts: CollectionEntry<'posts'>[] = await getCollection('posts');
  const talks = talksData as TalkMeta[];
  const externalArticles = externalArticlesData as ExternalArticleMeta[];

  const allTags = new Set<string>();

  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      allTags.add(tag);
    }
  }
  for (const talk of talks) {
    for (const tag of talk.tags ?? []) {
      allTags.add(tag);
    }
  }
  for (const article of externalArticles) {
    for (const tag of article.tags ?? []) {
      allTags.add(tag);
    }
  }

  return [...allTags].map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props as { tag: string };

const posts: CollectionEntry<'posts'>[] = await getCollection('posts');
const talks = talksData as TalkMeta[];
const externalArticles = externalArticlesData as ExternalArticleMeta[];

const timeline: TimelineItem[] = [
  ...posts
    .filter((post) => post.data.tags?.includes(tag))
    .map(
      (post): TimelineItem => ({
        kind: 'post',
        date: post.data.date,
        data: {
          title: post.data.title,
          slug: post.data.slug,
          description: post.data.description,
          tags: post.data.tags,
        },
      }),
    ),
  ...talks
    .filter((talk) => talk.tags?.includes(tag))
    .map(
      (talk): TimelineItem => ({
        kind: 'talk',
        date: talk.date,
        data: talk,
      }),
    ),
  ...externalArticles
    .filter((article) => article.tags?.includes(tag))
    .map(
      (article): TimelineItem => ({
        kind: 'external-article',
        date: article.date,
        data: article,
      }),
    ),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

const kindConfig = {
  post: {
    label: 'Post',
    className:
      'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
  talk: {
    label: 'Talk',
    className:
      'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
  'external-article': {
    label: 'External',
    className:
      'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
} as const;
---

<BaseLayout title={`${tag} - kosui`} ogTitle={tag}>
  <nav class="mb-6">
    <a
      href="/tags"
      class="inline-flex items-center gap-1 text-sm text-accent dark:text-accent-light hover:underline"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"
        >
        </path>
      </svg>
      Tags
    </a>
  </nav>

  <div class="flex items-center gap-3 mb-8">
    <h1 class="text-3xl font-bold">
      <span class="heading-accent">{tag}</span>
    </h1>
    <span class="text-sm text-subtle dark:text-[#9ca3af]">
      ({timeline.length} items)
    </span>
  </div>

  <ul class="space-y-4">
    {
      timeline.map((item) => {
        const { label, className } = kindConfig[item.kind];
        if (item.kind === 'post') {
          return (
        <li>
          <a
            href={`/${item.data.slug}`}
            class="block bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-subtle dark:text-[#9ca3af]"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >
                {label}
              </span>
            </div>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {item.data.title}
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags && item.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    item.data.tags.map((t) => (
                      <TagBadge tag={t} linked={false} />
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      );
        }
        if (item.kind === 'talk') {
          return (
        <li>
          <a
            href={`/talks/${item.data.year}/${item.data.name}`}
            class="block bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-subtle dark:text-[#9ca3af]"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >
                {label}
              </span>
            </div>
            {
              item.data.event && (
                <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
                  @ {item.data.event}
                </p>
              )
            }
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {item.data.title}
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    item.data.tags.map((t) => (
                      <TagBadge tag={t} linked={false} />
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      );
        }
        // external-article
        return (
        <li>
          <a
            href={item.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-subtle dark:text-[#9ca3af]"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >
                {label}
              </span>
            </div>
            <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
              @ {item.data.publisher}
            </p>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {item.data.title}
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    item.data.tags.map((t) => (
                      <TagBadge tag={t} linked={false} />
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      );
      })
    }
  </ul>
</BaseLayout>
