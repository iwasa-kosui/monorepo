---
import TagBadge from '@/components/TagBadge.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import externalArticlesData from '../content/external-articles/data.json';
import talksData from '../content/talks/data.json';

type PostEntry = CollectionEntry<'posts'>;

type TalkMeta = {
  title: string;
  date: string;
  event: string;
  tags: string[];
  duration: string;
  description: string;
  year: string;
  name: string;
  slideType: string;
};

type ExternalArticleMeta = {
  title: string;
  url: string;
  date: string;
  publisher: string;
  description?: string;
  tags: string[];
};

type TimelineItem =
  | {
    kind: 'post';
    date: string;
    data: {
      title: string;
      slug: string;
      description?: string;
      tags?: string[];
    };
  }
  | { kind: 'talk'; date: string; data: TalkMeta }
  | { kind: 'external-article'; date: string; data: ExternalArticleMeta };

const posts: PostEntry[] = await getCollection('posts');
const talks = talksData as TalkMeta[];
const externalArticles = externalArticlesData as ExternalArticleMeta[];

const timeline: TimelineItem[] = [
  ...posts.map((post): TimelineItem => ({
    kind: 'post',
    date: post.data.date,
    data: {
      title: post.data.title,
      slug: post.data.slug,
      description: post.data.description,
      tags: post.data.tags,
    },
  })),
  ...talks.map((talk): TimelineItem => ({
    kind: 'talk',
    date: talk.date,
    data: talk,
  })),
  ...externalArticles.map((article): TimelineItem => ({
    kind: 'external-article',
    date: article.date,
    data: article,
  })),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

const kindConfig = {
  post: {
    label: 'Post',
    className:
      'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
  talk: {
    label: 'Talk',
    className:
      'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
  'external-article': {
    label: 'External',
    className:
      'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
} as const;
---

<BaseLayout>
  <section class="mb-12">
    <div class="flex items-start gap-5">
      <img
        src="https://icon.kosui.me"
        alt="kosui"
        width="72"
        height="72"
        class="rounded-full ring-2 ring-accent/20 flex-shrink-0"
        transition:name="site-logo"
      />
      <div>
        <h1 class="text-2xl font-bold text-charcoal dark:text-gray-100">
          岩佐 幸翠 <span
            class="text-subtle dark:text-[#9ca3af] text-base font-normal"
          >/ kosui</span>
        </h1>
        <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
          テックリード @ 株式会社カケハシ
        </p>
        <p class="text-sm text-subtle dark:text-[#9ca3af] mt-2 leading-relaxed">
          医療SaaSの共通基盤を開発しています。認証認可基盤・組織管理・テナント分離などのプラットフォーム領域を担当。TypeScriptと関数型プログラミングを軸に、堅牢で型安全なシステム設計を実践しています。TSKaigi、関数型まつり、SRE
          Kaigiなどのカンファレンスで登壇。
        </p>
        <div class="flex flex-wrap gap-2 mt-3">
          <a
            href="https://github.com/iwasa-kosui"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1 text-xs rounded-full bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-[#ececec] hover:bg-accent/10 dark:hover:bg-accent/20 transition-colors"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
            </svg>
            GitHub
          </a>
          <a
            href="https://x.com/kosui_me"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1 text-xs rounded-full bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-[#ececec] hover:bg-accent/10 dark:hover:bg-accent/20 transition-colors"
          >
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
            X
          </a>
          <a
            href="https://speakerdeck.com/kakehashi"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 px-3 py-1 text-xs rounded-full bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-[#ececec] hover:bg-accent/10 dark:hover:bg-accent/20 transition-colors"
          >
            <svg
              class="w-3.5 h-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"
              />
            </svg>
            Speaker Deck
          </a>
        </div>
      </div>
    </div>
  </section>

  <h2 class="text-2xl font-bold mb-6">
    <span class="heading-accent">Timeline</span>
  </h2>
  <ul class="space-y-4">
    {
      timeline.map((item) => {
        const { label, className } = kindConfig[item.kind];
        if (item.kind === 'post') {
          return (
        <li>
          <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-subtle dark:text-[#9ca3af]"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >
                {label}
              </span>
            </div>
            <h2
              class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1"
              transition:name={`post-title-${item.data.slug}`}
            >
              <a href={`/${item.data.slug}`} class="card-link-overlay">
                {item.data.title}
              </a>
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags && item.data.tags.length > 0 && (
                <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                  {item.data.tags.map((tag) => <TagBadge tag={tag} />)}
                </div>
              )
            }
          </div>
        </li>
      );
        }
        if (item.kind === 'talk') {
          return (
        <li>
          <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-subtle dark:text-[#9ca3af]"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >
                {label}
              </span>
            </div>
            {
              item.data.event && (
                <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
                  @ {item.data.event}
                </p>
              )
            }
            <h2
              class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1"
              transition:name={`talk-title-${item.data.year}-${item.data.name}`}
            >
              <a
                href={`/talks/${item.data.year}/${item.data.name}`}
                class="card-link-overlay"
              >
                {item.data.title}
              </a>
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags.length > 0 && (
                <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                  {item.data.tags.map((tag) => <TagBadge tag={tag} />)}
                </div>
              )
            }
          </div>
        </li>
      );
        }
        // external-article
        return (
        <li>
          <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-subtle dark:text-[#9ca3af]"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >
                {label}
              </span>
            </div>
            <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
              @ {item.data.publisher}
            </p>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              <a
                href={item.data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="card-link-overlay"
              >
                {item.data.title}
              </a>
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags.length > 0 && (
                <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                  {item.data.tags.map((tag) => <TagBadge tag={tag} />)}
                </div>
              )
            }
          </div>
        </li>
      );
      })
    }
  </ul>
</BaseLayout>
