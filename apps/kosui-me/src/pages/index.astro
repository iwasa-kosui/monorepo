---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import externalArticlesData from '../content/external-articles/data.json';
import talksData from '../content/talks/data.json';

type PostEntry = CollectionEntry<'posts'>;

type TalkMeta = {
  title: string;
  date: string;
  event: string;
  tags: string[];
  duration: string;
  description: string;
  year: string;
  name: string;
  slideType: string;
};

type ExternalArticleMeta = {
  title: string;
  url: string;
  date: string;
  publisher: string;
  description?: string;
  tags: string[];
};

type TimelineItem =
  | {
    kind: 'post';
    date: string;
    data: {
      title: string;
      slug: string;
      description?: string;
      tags?: string[];
    };
  }
  | { kind: 'talk'; date: string; data: TalkMeta }
  | { kind: 'external-article'; date: string; data: ExternalArticleMeta };

const posts: PostEntry[] = await getCollection('posts');
const talks = talksData as TalkMeta[];
const externalArticles = externalArticlesData as ExternalArticleMeta[];

const timeline: TimelineItem[] = [
  ...posts.map((post): TimelineItem => ({
    kind: 'post',
    date: post.data.date,
    data: {
      title: post.data.title,
      slug: post.data.slug,
      description: post.data.description,
      tags: post.data.tags,
    },
  })),
  ...talks.map((talk): TimelineItem => ({
    kind: 'talk',
    date: talk.date,
    data: talk,
  })),
  ...externalArticles.map((article): TimelineItem => ({
    kind: 'external-article',
    date: article.date,
    data: article,
  })),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

const kindConfig = {
  post: {
    label: 'Post',
    className:
      'bg-terracotta/10 text-terracotta dark:bg-terracotta/20 dark:text-terracotta-light',
  },
  talk: {
    label: 'Talk',
    className: 'bg-teal/10 text-teal dark:bg-teal/20 dark:text-teal',
  },
  'external-article': {
    label: 'External',
    className:
      'bg-steel-blue/10 text-steel-blue dark:bg-steel-blue/20 dark:text-steel-blue',
  },
} as const;
---

<BaseLayout>
  <h1 class="text-3xl font-bold mb-8">Timeline</h1>
  <ul class="space-y-4">
    {
      timeline.map((item) => {
        const { label, className } = kindConfig[item.kind];
        if (item.kind === 'post') {
          return (
        <li>
          <a
            href={`/${item.data.slug}`}
            class="block bg-cream dark:bg-[#2d2a28] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-terracotta dark:text-terracotta-light"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >{label}</span>
            </div>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {item.data.title}
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-charcoal-light dark:text-warm-gray">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags && item.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    item.data.tags.map((tag) => (
                      <span
                        class="inline-block px-2 py-0.5 text-xs rounded-full bg-sand-light dark:bg-[#3d3835] text-charcoal-light dark:text-warm-gray"
                      >
                        {tag}
                      </span>
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      );
        }
        if (item.kind === 'talk') {
          return (
        <li>
          <a
            href={`/talks/${item.data.year}/${item.data.name}/`}
            class="block bg-cream dark:bg-[#2d2a28] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-terracotta dark:text-terracotta-light"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >{label}</span>
            </div>
            {
              item.data.event && (
                <p class="text-sm font-medium text-teal dark:text-teal mt-1">
                  @ {item.data.event}
                </p>
              )
            }
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {item.data.title}
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-charcoal-light dark:text-warm-gray">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    item.data.tags.map((tag) => (
                      <span
                        class="inline-block px-2 py-0.5 text-xs rounded-full bg-sand-light dark:bg-[#3d3835] text-charcoal-light dark:text-warm-gray"
                      >
                        {tag}
                      </span>
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      );
        }
        // external-article
        return (
        <li>
          <a
            href={item.data.url}
            target="_blank"
            rel="noopener noreferrer"
            class="block bg-cream dark:bg-[#2d2a28] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <div class="flex items-center gap-2">
              <time
                class="text-xs text-terracotta dark:text-terracotta-light"
                datetime={item.date}
              >
                {formatDate(item.date)}
              </time>
              <span
                class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}
              >{label}</span>
            </div>
            <p class="text-sm font-medium text-steel-blue dark:text-steel-blue mt-1">
              @ {item.data.publisher}
            </p>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {item.data.title}
            </h2>
            {
              item.data.description && (
                <p class="mt-1 text-sm text-charcoal-light dark:text-warm-gray">
                  {item.data.description}
                </p>
              )
            }
            {
              item.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    item.data.tags.map((tag) => (
                      <span
                        class="inline-block px-2 py-0.5 text-xs rounded-full bg-sand-light dark:bg-[#3d3835] text-charcoal-light dark:text-warm-gray"
                      >
                        {tag}
                      </span>
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      );
      })
    }
  </ul>
</BaseLayout>
