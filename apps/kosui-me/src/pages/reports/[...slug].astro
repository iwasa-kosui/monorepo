---
import AuthorCard from '@/components/AuthorCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection, render } from 'astro:content';

type ReportEntry = CollectionEntry<'reports'>;

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((report: ReportEntry) => ({
    params: { slug: report.data.slug },
    props: { report },
  }));
}

const { report } = Astro.props as { report: ReportEntry };
const { Content } = await render(report);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout
  ogTitle={`🤖 ${report.data.title}`}
  ogDescription={report.data.description}
  noindex={true}
>
  <article class="article-paper">
    <header class="mb-8">
      <time
        class="text-sm text-accent dark:text-accent-light"
        datetime={report.data.date}
      >
        {formatDate(report.data.date)}
      </time>
      <h1
        class="text-3xl font-bold mt-2 mb-4"
        transition:name={`report-title-${report.data.slug}`}
      >
        🤖 {report.data.title}
      </h1>
      <AuthorCard />
    </header>
    <aside class="mb-6 p-4 border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-950/30 dark:border-amber-400 rounded-r-lg text-sm text-amber-900 dark:text-amber-200">
      <p class="font-bold mb-1">本記事は生成AIによって作成されたものです</p>
      <p class="mb-1">内容の正確性は保証されません。事実関係や技術的な記述については、必ず一次情報源をご確認ください。</p>
      <p>また、本記事をSNS等で共有・拡散する際は、AI生成コンテンツである旨を併記するなど、誤解を招かないようご配慮ください。</p>
    </aside>
    <div class="prose">
      <Content />
    </div>
  </article>

  <section class="p-4 bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark">
    <AuthorCard />
  </section>

  <script>
  document.addEventListener('astro:page-load', async () => {
    const mermaidElements = document.querySelectorAll<HTMLPreElement>(
      'pre.mermaid',
    );
    if (mermaidElements.length > 0) {
      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({ startOnLoad: false, theme: 'neutral' });
      await mermaid.run({ nodes: mermaidElements });
    }
  });
  </script>
</BaseLayout>
