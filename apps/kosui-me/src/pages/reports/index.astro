---
import ThemeBadge from '@/components/ThemeBadge.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection } from 'astro:content';

type ReportEntry = CollectionEntry<'reports'>;

const reports: ReportEntry[] = await getCollection('reports');
const sortedReports: ReportEntry[] = reports.sort(
  (a: ReportEntry, b: ReportEntry) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout title="Reports - kosui" ogTitle="Reports" noindex={true}>
  <h1 class="text-3xl font-bold mb-8">
    <span class="heading-accent">Reports</span>
  </h1>
  <aside class="mb-6 p-4 border-l-4 border-amber-500 bg-amber-50 dark:bg-amber-950/30 dark:border-amber-400 rounded-r-lg text-sm text-amber-900 dark:text-amber-200">
    <p>
      本セクションの記事は生成AIによって作成されたものです。内容の正確性は保証されません。SNS等での拡散時はAI生成コンテンツである旨の併記をお願いします。
    </p>
  </aside>
  <ul class="space-y-4">
    {
      sortedReports.map((report) => (
        <li>
          <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
            <time
              class="text-xs text-accent dark:text-accent-light"
              datetime={report.data.date}
            >
              {formatDate(report.data.date)}
            </time>
            <h2
              class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1"
              transition:name={`report-title-${report.data.slug}`}
            >
              <a
                href={`/reports/${report.data.slug}`}
                class="card-link-overlay"
              >
                生成AIレポート: {report.data.title}
              </a>
            </h2>
            {
              report.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">
                  {report.data.description}
                </p>
              )
            }
            {
              report.data.themes && report.data.themes.length > 0
            && (
                <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                  {
                    report.data.themes.map((theme: string) => (
                      <ThemeBadge theme={theme} />
                    ))
                  }
                </div>
              )
            }
          </div>
        </li>
      ))
    }
  </ul>
</BaseLayout>
