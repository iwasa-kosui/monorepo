---
import BaseLayout from '@/layouts/BaseLayout.astro';

const careers = [
  {
    company: '株式会社カケハシ',
    role: 'テックリード',
    period: '2022年8月〜現在',
    description:
      '組織管理・認証認可プラットフォームチームのテックリード。医療SaaSの共通基盤（認証認可、ライセンス管理、テナント分離）を設計・開発。',
    techs: ['TypeScript', 'Node.js', 'PostgreSQL', 'AWS', 'fp-ts', 'Zod'],
  },
  {
    company: '株式会社ディー・エヌ・エー（DeNA）',
    role: 'Webエンジニア',
    period: '2019年4月〜2023年4月',
    description:
      'タクシー配車アプリ「MOV」（現: GO）の業務管理システムを開発。大規模ログ基盤の構築やUser-Agent削減対策に取り組む。',
    techs: ['Go', 'Vue.js', 'TypeScript', 'GAE', 'ECS on Fargate'],
  },
] as const;

const talks = [
  {
    year: '2026',
    event: 'SRE KAIGI 2026',
    title:
      '開発チームが信頼性向上のためにできること — 医療SaaS企業を支える共通基盤の挑戦',
  },
  {
    year: '2025',
    event: '関数型まつり 2025',
    title: '堅牢な認証基盤の実現: TypeScriptで代数的データ型を活用する',
  },
  {
    year: '2024',
    event: 'TSKaigi 2024',
    title:
      '複雑なビジネスルールに挑む: 正確性と効率性を両立するfp-tsのチーム活用術',
  },
] as const;

const links = [
  { label: 'GitHub', href: 'https://github.com/iwasa-kosui', icon: 'github' },
  { label: 'X (Twitter)', href: 'https://x.com/kosui_me', icon: 'x' },
  {
    label: 'Google Scholar',
    href: 'https://scholar.google.com/citations?user=DaujMhUAAAAJ&hl=ja',
    icon: 'scholar',
  },
  {
    label: 'Speaker Deck',
    href: 'https://speakerdeck.com/kakehashi',
    icon: 'slides',
  },
] as const;
---

<BaseLayout
  title="About - kosui"
  ogTitle="About"
  description="岩佐幸翠（kosui）のプロフィール。TypeScript, Platform Engineering, 関数型プログラミングを専門とするテックリード。"
>
  <h1 class="text-3xl font-bold mb-8">
    <span class="heading-accent">About</span>
  </h1>

  <!-- Profile -->
  <section class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 mb-8">
    <div class="flex flex-col sm:flex-row items-start gap-5">
      <img
        src="https://icon.kosui.me"
        alt="kosui"
        width="80"
        height="80"
        class="rounded-full ring-2 ring-accent/20 flex-shrink-0"
      />
      <div class="min-w-0">
        <h2 class="text-xl font-bold text-charcoal dark:text-gray-100">
          岩佐 幸翠
          <span class="text-sm font-normal text-subtle dark:text-[#9ca3af]"
          >/ Kosui Iwasa</span>
        </h2>
        <p class="text-sm text-accent dark:text-accent-light font-medium mt-1">
          テックリード @ 株式会社カケハシ
        </p>
        <p class="text-sm text-subtle dark:text-[#9ca3af] mt-2 leading-relaxed">
          医療SaaS企業にて認証認可・組織管理などの共通基盤をテックリードとして設計・開発しています。TypeScriptと関数型プログラミング（fp-ts,
          代数的データ型, Railway Oriented
          Programming）を活用し、堅牢なシステムを構築しています。
        </p>
        <div class="flex flex-wrap gap-2 mt-3">
          {
            links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 px-3 py-1 text-xs rounded-full bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-[#9ca3af] hover:text-accent dark:hover:text-accent-light transition-colors"
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-4">専門領域</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-5">
        <h3 class="font-semibold text-charcoal dark:text-gray-100 mb-2">
          Platform Engineering
        </h3>
        <p class="text-sm text-subtle dark:text-[#9ca3af] leading-relaxed">
          認証認可基盤（OpenID Connect / OAuth
          2.0）、ライセンス管理、組織階層フレームワーク、マルチテナントアーキテクチャ（PostgreSQL
          RLS）の設計・構築
        </p>
      </div>
      <div class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-5">
        <h3 class="font-semibold text-charcoal dark:text-gray-100 mb-2">
          TypeScript / 関数型プログラミング
        </h3>
        <p class="text-sm text-subtle dark:text-[#9ca3af] leading-relaxed">
          fp-ts、代数的データ型、Railway Oriented Programming、Schema-Driven
          Development（Zod + Branded Type）によるAlways-Valid Domain Modelの実現
        </p>
      </div>
      <div class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-5">
        <h3 class="font-semibold text-charcoal dark:text-gray-100 mb-2">
          設計パターン
        </h3>
        <p class="text-sm text-subtle dark:text-[#9ca3af] leading-relaxed">
          ドメイン駆動設計（DDD）、イベント駆動設計、CQRS / Outbox
          パターン、Delta Lakeを活用したデータパイプライン
        </p>
      </div>
      <div class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-5">
        <h3 class="font-semibold text-charcoal dark:text-gray-100 mb-2">
          信頼性エンジニアリング
        </h3>
        <p class="text-sm text-subtle dark:text-[#9ca3af] leading-relaxed">
          3省2ガイドラインに準拠した医療情報システムの設計。インシデント調査時間を2〜3時間から30分に短縮する仕組みの構築
        </p>
      </div>
    </div>
  </section>

  <!-- Career -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-4">経歴</h2>
    <div class="space-y-4">
      {
        careers.map((career) => (
          <div class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-5">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-2">
              <h3 class="font-semibold text-charcoal dark:text-gray-100">
                {career.company}
              </h3>
              <span class="text-xs text-subtle dark:text-[#9ca3af]">
                {career.period}
              </span>
            </div>
            <p class="text-sm text-accent dark:text-accent-light font-medium mb-2">
              {career.role}
            </p>
            <p class="text-sm text-subtle dark:text-[#9ca3af] leading-relaxed mb-3">
              {career.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {
                career.techs.map((tech) => (
                  <span
                    class="px-2 py-0.5 text-xs rounded-full bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-[#9ca3af]"
                  >
                    {tech}
                  </span>
                ))
              }
            </div>
          </div>
        ))
      }
    </div>
    <p class="text-xs text-subtle dark:text-[#9ca3af] mt-3">
      東京農工大学大学院
      工学府修了（人工知能・マルチエージェントシステム・自然言語処理）
    </p>
  </section>

  <!-- Talks -->
  <section class="mb-8">
    <h2 class="text-xl font-bold mb-4">主な登壇</h2>
    <div class="space-y-3">
      {
        talks.map((talk) => (
          <div class="bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-4 flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-4">
            <div class="flex items-center gap-2 sm:flex-col sm:items-end sm:gap-0 flex-shrink-0">
              <span
                class="text-xs font-semibold text-accent dark:text-accent-light"
              >
                {talk.year}
              </span>
              <span class="text-xs text-subtle dark:text-[#9ca3af]">
                {talk.event}
              </span>
            </div>
            <p class="text-sm text-charcoal dark:text-gray-100 leading-relaxed">
              {talk.title}
            </p>
          </div>
        ))
      }
    </div>
    <p class="mt-3">
      <a
        href="/talks"
        class="text-sm text-accent dark:text-accent-light hover:text-accent-dark dark:hover:text-white transition-colors"
      >
        すべての登壇を見る &rarr;
      </a>
    </p>
  </section>

  <!-- Blog -->
  <section class="mb-4">
    <h2 class="text-xl font-bold mb-4">このサイトについて</h2>
    <div class="prose">
      <p>
        TypeScript, Node.js,
        インフラなどサーバサイド開発に関する知見を発信しています。
      </p>
    </div>
  </section>
</BaseLayout>
