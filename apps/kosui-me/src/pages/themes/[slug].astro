---
import ThemeBadge from '@/components/ThemeBadge.astro';
import { getAllThemes, getTheme } from '@/config/themes';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection } from 'astro:content';
import externalArticlesData from '../../content/external-articles/data.json';
import talksData from '../../content/talks/data.json';

type TalkMeta = {
  title: string;
  date: string;
  event: string;
  themes: string[];
  duration: string;
  description: string;
  year: string;
  name: string;
  slideType: string;
};

type ExternalArticleMeta = {
  title: string;
  url: string;
  date: string;
  publisher: string;
  description?: string;
  themes: string[];
};

type TimelineItem =
  | {
    kind: 'post';
    date: string;
    data: {
      title: string;
      slug: string;
      description?: string;
      themes?: string[];
    };
  }
  | { kind: 'talk'; date: string; data: TalkMeta }
  | { kind: 'external-article'; date: string; data: ExternalArticleMeta };

export function getStaticPaths() {
  return getAllThemes().map((theme) => ({
    params: { slug: theme.slug },
  }));
}

const { slug } = Astro.params;
const theme = getTheme(slug!)!;
const otherThemes = getAllThemes().filter((t) => t.slug !== slug);

const allPosts: CollectionEntry<'posts'>[] = await getCollection('posts');
const posts = allPosts.filter((post) => !post.data.private);
const talks = talksData as TalkMeta[];
const externalArticles = externalArticlesData as ExternalArticleMeta[];

const timeline: TimelineItem[] = [
  ...posts
    .filter((post) => post.data.themes?.includes(slug!))
    .map((post): TimelineItem => ({
      kind: 'post',
      date: post.data.date,
      data: {
        title: post.data.title,
        slug: post.data.slug,
        description: post.data.description,
        themes: post.data.themes,
      },
    })),
  ...talks
    .filter((talk) => talk.themes?.includes(slug!))
    .map((talk): TimelineItem => ({
      kind: 'talk',
      date: talk.date,
      data: talk,
    })),
  ...externalArticles
    .filter((article) => article.themes?.includes(slug!))
    .map((article): TimelineItem => ({
      kind: 'external-article',
      date: article.date,
      data: article,
    })),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

const kindConfig = {
  post: {
    label: 'Post',
    className: 'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
  talk: {
    label: 'Talk',
    className: 'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
  'external-article': {
    label: 'External',
    className: 'bg-accent/10 text-accent dark:bg-accent/20 dark:text-accent-light',
  },
} as const;
---

<BaseLayout title={`${theme.name} - kosui`} ogTitle={theme.name}>
  <header class="mb-8">
    <h1 class="text-3xl font-bold mb-2">
      <span class="heading-accent">{theme.name}</span>
    </h1>
    <p class="text-sm text-subtle dark:text-[#9ca3af] leading-relaxed">
      {theme.description}
    </p>
    <p class="text-xs text-subtle dark:text-[#9ca3af] mt-2">
      {timeline.length} articles
    </p>
  </header>

  <nav class="mb-8 flex flex-wrap gap-2">
    <span class="text-xs text-subtle dark:text-[#9ca3af] py-1">他のテーマ:</span>
    {otherThemes.map((t) => (
      <a
        href={`/themes/${t.slug}`}
        class="text-xs px-3 py-1 rounded-full border border-border dark:border-[#2a2a32] text-subtle dark:text-[#9ca3af] hover:bg-accent/10 dark:hover:bg-accent/20 transition-colors"
      >
        {t.name}
      </a>
    ))}
  </nav>

  <ul class="space-y-4">
    {timeline.map((item) => {
      const { label, className } = kindConfig[item.kind];
      if (item.kind === 'post') {
        return (
          <li>
            <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
              <div class="flex items-center gap-2">
                <time class="text-xs text-subtle dark:text-[#9ca3af]" datetime={item.date}>
                  {formatDate(item.date)}
                </time>
                <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}>
                  {label}
                </span>
              </div>
              <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1" transition:name={`post-title-${item.data.slug}`}>
                <a href={`/${item.data.slug}`} class="card-link-overlay">
                  {item.data.title}
                </a>
              </h2>
              {item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">{item.data.description}</p>
              )}
              {item.data.themes && item.data.themes.length > 0 && (
                <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                  {item.data.themes.map((t) => <ThemeBadge theme={t} />)}
                </div>
              )}
            </div>
          </li>
        );
      }
      if (item.kind === 'talk') {
        return (
          <li>
            <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
              <div class="flex items-center gap-2">
                <time class="text-xs text-subtle dark:text-[#9ca3af]" datetime={item.date}>
                  {formatDate(item.date)}
                </time>
                <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}>
                  {label}
                </span>
              </div>
              {item.data.event && (
                <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
                  @ {item.data.event}
                </p>
              )}
              <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1" transition:name={`talk-title-${item.data.year}-${item.data.name}`}>
                <a href={`/talks/${item.data.year}/${item.data.name}`} class="card-link-overlay">
                  {item.data.title}
                </a>
              </h2>
              {item.data.description && (
                <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">{item.data.description}</p>
              )}
              {item.data.themes.length > 0 && (
                <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                  {item.data.themes.map((t) => <ThemeBadge theme={t} />)}
                </div>
              )}
            </div>
          </li>
        );
      }
      // external-article
      return (
        <li>
          <div class="relative bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover">
            <div class="flex items-center gap-2">
              <time class="text-xs text-subtle dark:text-[#9ca3af]" datetime={item.date}>
                {formatDate(item.date)}
              </time>
              <span class={`inline-block px-2 py-0.5 text-xs font-medium rounded-full ${className}`}>
                {label}
              </span>
            </div>
            <p class="text-sm font-semibold text-accent dark:text-accent-light mt-1">
              @ {item.data.publisher}
            </p>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              <a href={item.data.url} target="_blank" rel="noopener noreferrer" class="card-link-overlay">
                {item.data.title}
              </a>
            </h2>
            {item.data.description && (
              <p class="mt-1 text-sm text-subtle dark:text-[#9ca3af]">{item.data.description}</p>
            )}
            {item.data.themes.length > 0 && (
              <div class="relative z-10 mt-2 flex flex-wrap gap-1.5">
                {item.data.themes.map((t) => <ThemeBadge theme={t} />)}
              </div>
            )}
          </div>
        </li>
      );
    })}
  </ul>
</BaseLayout>
