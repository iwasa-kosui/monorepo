---
import BaseLayout from '@/layouts/BaseLayout.astro';
import externalArticlesData from '../content/external-articles/data.json';
import talksData from '../content/talks/data.json';
import { getCollection, render } from 'astro:content';

type TalkMeta = {
  title: string;
  date: string;
  event: string;
  tags: string[];
  duration: string;
  description: string;
  year: string;
  name: string;
  slideType: string;
};

type ExternalArticleMeta = {
  title: string;
  url: string;
  date: string;
  publisher: string;
  description?: string;
  tags: string[];
};

const talks = (talksData as TalkMeta[]).filter((t) => t.event !== '社内LT');
const externalArticles = externalArticlesData as ExternalArticleMeta[];

const resumeEntries = await getCollection('resume');
const resumeEntry = resumeEntries[0];
if (!resumeEntry) {
  throw new Error('Resume content not found');
}
const { Content } = await render(resumeEntry);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout
  title="職務経歴書 - kosui"
  ogTitle="職務経歴書"
  ogDescription={resumeEntry.data.description}
>
  <article class="article-paper">
    <div class="prose">
      <Content />
    </div>

    <!-- 社外活動 -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">
        <span class="heading-accent">社外活動</span>
      </h2>

      <h3 class="text-lg font-bold text-charcoal dark:text-gray-100 mb-3">
        登壇
      </h3>
      <div class="space-y-2 mb-6">
        {
          talks.map((talk) => (
            <a
              href={`/talks/${talk.year}/${talk.name}`}
              class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 border border-border dark:border-[#2a2a32] rounded-xl p-4 hover:bg-tag-bg dark:hover:bg-[#2a2a32] transition-colors"
            >
              <span
                class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap flex-shrink-0"
              >
                {formatDate(talk.date)}
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-base font-semibold text-charcoal dark:text-gray-100 leading-snug">
                  {talk.title}
                </p>
                <p class="text-sm text-accent dark:text-accent-light mt-0.5">
                  @ {talk.event}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <h3 class="text-lg font-bold text-charcoal dark:text-gray-100 mb-3">
        執筆
      </h3>
      <div class="space-y-2">
        {
          externalArticles.map((article) => (
            <a
              href={article.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 border border-border dark:border-[#2a2a32] rounded-xl p-4 hover:bg-tag-bg dark:hover:bg-[#2a2a32] transition-colors"
            >
              <span
                class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap flex-shrink-0"
              >
                {formatDate(article.date)}
              </span>
              <div class="flex-1 min-w-0">
                <p class="text-base font-semibold text-charcoal dark:text-gray-100 leading-snug">
                  {article.title}
                </p>
                <p class="text-sm text-accent dark:text-accent-light mt-0.5">
                  @ {article.publisher}
                </p>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>
