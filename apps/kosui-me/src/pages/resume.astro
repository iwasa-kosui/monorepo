---
import BaseLayout from '@/layouts/BaseLayout.astro';
import externalArticlesData from '../content/external-articles/data.json';
import talksData from '../content/talks/data.json';

type TalkMeta = {
  title: string;
  date: string;
  event: string;
  tags: string[];
  duration: string;
  description: string;
  year: string;
  name: string;
  slideType: string;
};

type ExternalArticleMeta = {
  title: string;
  url: string;
  date: string;
  publisher: string;
  description?: string;
  tags: string[];
};

const talks = (talksData as TalkMeta[]).filter((t) => t.event !== '社内LT');
const externalArticles = externalArticlesData as ExternalArticleMeta[];

const basicInfo = [
  { label: '氏名', value: '岩佐 幸翠（いわさ こうすい）' },
  { label: '生年', value: '1994年' },
  {
    label: '最終学歴',
    value: '東京農工大学大学院 工学府 情報工学専攻 修士（工学）',
  },
  {
    label: 'GitHub',
    value: 'iwasa-kosui',
    href: 'https://github.com/iwasa-kosui',
  },
  {
    label: '技術ブログ',
    value: 'kosui.me',
    href: 'https://kosui.me',
  },
];

type Phase = {
  label: string;
  items: string[];
};

type Project = {
  title: string;
  period: string;
  role: string;
  summary: string;
  phases?: Phase[];
  achievements?: string[];
  techStack: string[];
};

type Career = {
  period: string;
  org: string;
  description: string;
  projects: Project[];
};

const careers: Career[] = [
  {
    period: '2022年8月 - 現在',
    org: '株式会社カケハシ',
    description:
      '事業内容: 医療プラットフォームの開発・運営（従業員数 約350名）',
    projects: [
      {
        title: '認証・認可基盤',
        period: '2022年下期 - 2025年下期',
        role: 'バックエンドエンジニア → テックリード → PdM兼テックリード',
        summary:
          'パートナー企業のIdPとのSSO連携を皮切りに、厚生労働省ガイドラインを背景とした全社統一認証基盤の構築、6以上のプロダクトの移行統括までを一貫してリード。',
        phases: [
          {
            label: 'SSO連携基盤構築（2022年下期）',
            items: [
              'OIDC標準プロトコルによる汎用SSO基盤を構築し、任意のOIDC準拠IdPと接続可能な設計を実現',
              '他プロダクトチームへのSSOサンプル実装の提供、OIDC認可コードフローにおけるCSRF対策の設計レビューなど、チームを超えた技術支援を実施',
            ],
          },
          {
            label:
              '技術検証・選定（2023年上期 - 2024年上期 / バックエンド2名、PdMなし）',
            items: [
              '行政ガイドラインによるMFA義務化に対し、薬局でのスマートフォン持ち込み制約やキオスク端末の共用利用を踏まえ、独自MFA方式の実装が必須と判断。IDaaSのHookベースのカスタマイズではMFA要件がHookの品質に依存し事業継続リスクを伴うため、認証ロジックまで自前で制御可能なAuthleteを選定',
              'Authleteの決め手: トークン・署名鍵・プロトコル処理の難所を移管でき開発負荷を軽減しつつ、FAPI対応により将来の規制強化（NIST→厚労省ガイドラインへの反映傾向）にも備えられる点。認証フローのフロントエンド・バックエンド自前実装というトレードオフを受容',
              '3フェーズのマイルストーンと予算の蓋然性を含む提案で経営層の承認を獲得',
              '「セキュリティ」「可用性」「移植性」「運用性」の4軸で技術選定方針を定義し、メンバーが主体的に判断できるプロセスを導入',
              '新メンバーのオンボーディング: 毎日の1on1、ペアプロ、社外勉強会の共催など多角的なアプローチで実施',
            ],
          },
          {
            label: '本開発・セキュリティ強化（2024年上期 - 下期）',
            items: [
              'SREチームと協業しDFDベースの脅威モデリングを実施。事業インパクトに基づくセキュリティロードマップを策定',
              'TypeScript、データモデリング、DynamoDBテーブル設計等のスキルを体系的に移転し、後任が独立してチームを牽引できる状態を実現',
            ],
          },
          {
            label: '移行統括・パスワードポリシー・外部連携（2025年上期 - 下期）',
            items: [
              '6以上のプロダクトの移行統括: URIリダイレクト問題、JWT検証失敗、CORS設定、Electronアプリ固有のOAuthフロー問題など、プロダクトごとの技術課題を解決',
              'パスワードポリシー機能のEnd-to-End推進: 要求分析から運用設計までを統括。チームメイトを巻き込みRDRAによる要求分析をFigJam上のユースケース図やロバストネス図を用いて対話的に実施し、要求分析のナレッジ・経験をチームへ移転',
              '外部LMS（学習管理システム）との認証連携の仕様策定をPdM不在の中で主導し、複数チーム間の仕様齟齬を解消',
              'サービスベースアーキテクチャ（認証/ディレクトリ/アセットの3ドメイン分割）の推進をチームメイトに委譲し、メンバーが主体的にADR作成や中核的設計を引き受ける状態を定着',
            ],
          },
        ],
        techStack: [
          'Authlete',
          'Auth0',
          'AWS Cognito',
          'OpenID Connect',
          'TypeScript',
          'React (SSR)',
          'DynamoDB',
          'PostgreSQL',
          'Okta',
          'AppSync',
          'Lambda',
        ],
      },
      {
        title: '組織管理基盤',
        period: '2023年上期 - 下期',
        role: 'テックリード兼PdM代行',
        summary:
          '各プロダクトを横断する組織管理基盤の開発。前任テックリードから引き継ぎ、PdM代行も担当。',
        phases: [
          {
            label: '要求分析・スコープ最適化',
            items: [
              'エンタープライズ顧客と中小規模顧客で課題が異なることを発見し、「管理UIの新規開発」ではなく「Excelによる一括インポート」で要求を満たせることを明らかにし、運用フローを再設計した上で優先すべき要件を「充実した機能」ではなく「データの可用性と一貫性」であると判断。4ヶ月の前倒し提供を実現',
              'ドメインモデルの簡素化: 複雑化していたモデルを実際の要求に基づいて再設計し、実装速度と保守性を向上',
            ],
          },
          {
            label: '設計・実装',
            items: [
              'S3+Delta Lakeによるデータ連携方式の選定: プロダクトチームの本質的な要求を見極め、API連携ではなくデータの一貫性と可用性を重視した設計を採用',
            ],
          },
          {
            label: '運用・展開',
            items: [
              '利用者向けガイドの体系化: 他チームからの問い合わせを大幅に減少させ、自発的にガイドを参照する文化を定着',
              '新規メンバーの立ち上げ: 1日2回15分のペアプロで同期的なコミュニケーションの場を設け、独力でタスクを遂行できる状態へ育成',
            ],
          },
        ],
        techStack: [
          'TypeScript',
          'NestJS',
          'fp-ts',
          'ヘキサゴナルアーキテクチャ',
          'Databricks',
          'DynamoDB',
        ],
      },
      {
        title: '端末・ライセンス管理',
        period: '2024年下期 - 2025年下期',
        role: 'テックリード兼PdM代行',
        summary:
          '認証基盤と連動する端末管理・ライセンス管理機能の構築。業務フロー未確定かつ正確な台帳も存在しない状況下で、複数部門と連携しながらシステムと運用の両面を設計。',
        phases: [
          {
            label: '組織横断推進・業務フロー整備',
            items: [
              'ライセンス管理の組織横断的推進: 販売管理・アカウント管理・プロダクト開発チームと連携し、高い不確実性の中で手戻りなくリリースへ到達',
              '5部門以上の横断調整: カスタマーサクセス・セールスオペレーション・営業など各部門で保持する情報の差異を整理し、運用ガイド作成を通じて部門間の認識を統一',
              'セールスオペレーション部門と連携し、未定義だった業務フローの明確化を主導。外部システムとの連携仕様をドキュメント化',
            ],
          },
          {
            label: 'システム設計・実装',
            items: [
              '4ドメイン（証明書・保証書・端末・ライセンス）が絡み合う業務フローの段階的設計と外部システム統合',
              '正確なデバイス台帳が存在しない中で、4つのデータソース間の不整合を前提としたシステム設計を実施。取込エラー時の切り分けフローと手動復旧ワークフローを整備',
            ],
          },
          {
            label: '障害対応・改善',
            items: [
              'ポストモーテムを通じて構造的課題を可視化し、再発防止策をシステム設計に反映',
            ],
          },
        ],
        techStack: [
          'TypeScript',
          'React (SSR)',
          'Zod',
          'DynamoDB',
          'PostgreSQL',
        ],
      },
    ],
  },
  {
    period: '2019年4月 - 2022年8月',
    org: '株式会社ディー・エヌ・エー',
    description:
      '事業内容: モバイルゲーム、スポーツ、ヘルスケア等の多角的インターネットサービス',
    projects: [
      {
        title: '認証認可プラットフォームのリノベーション',
        period: '2020年8月 - 2022年8月',
        role: 'Webエンジニア',
        summary:
          '大規模かつグローバルな認証認可プラットフォームの段階的リノベーション。長期運用を見据え、運用を止めずにEC2からECS、Perl (PSGI) からJava (Quarkus) への移行を設計・実行。',
        achievements: [
          'サービス群の分割境界を決定。サービス間のピンポンを回避するため密集度を高める設計方針を策定',
          'BFFアプリケーションのコードアーキテクチャをコンペ形式で選定',
          'ペアレンタルコントロール機能のマイクロサービス化を設計。既存概念を整理・ドキュメント化し、業務ロジックを抽象化したRPCライクなAPI設計を実現',
          'BFFアプリケーションのインフラ構築（ECS + DynamoDB）',
        ],
        techStack: [
          'Java (Quarkus)',
          'Perl',
          'TypeScript',
          'React',
          'AWS (ECS, DynamoDB)',
        ],
      },
      {
        title: '認証認可プラットフォームの開発・運用',
        period: '2020年1月 - 2020年7月',
        role: 'Webエンジニア',
        summary:
          '大規模かつグローバルな認証認可プラットフォームの開発と運用。',
        achievements: [
          'Firestoreにおけるクエリを改善しインフラコストを削減',
          'Chrome User-Agent文字列削減とUA-CHの導入に伴うサービス影響の調査・対応策の立案・設計を主導',
        ],
        techStack: [
          'Go',
          'TypeScript',
          'React',
          'AWS (ECS, Fargate, FireLens)',
          'Firestore',
        ],
      },
      {
        title: 'タクシー配車アプリ業務管理システム',
        period: '2019年4月 - 2020年1月',
        role: 'Webエンジニア',
        summary:
          'タクシー配車アプリ「MOV」（現: GO）のタクシー事業者向け管理アプリケーションの運用改善。',
        achievements: [
          'CSチームからのヒアリングに基づき改善策を提案し、詳細設計・実装を通じて事業の運用工数を削減',
          'React / TypeScript によるフロントエンド開発、Go によるバックエンドAPI開発',
        ],
        techStack: ['React', 'TypeScript', 'Go'],
      },
    ],
  },
];

const education = [
  {
    period: '2017年4月 - 2019年3月',
    org: '東京農工大学大学院 工学府 情報工学専攻',
    degree: '修士（工学）',
    description:
      '人工知能・マルチエージェントシステム・自然言語処理を研究。論文採択: EACL \'21, WWW \'19, PRICAI \'18',
  },
  {
    period: '2013年4月 - 2017年3月',
    org: '東京農工大学 工学部 情報工学科',
    degree: '学士（工学）',
    description: '',
  },
];

const skillCategories = [
  {
    category: '認証・認可',
    skills: [
      'OpenID Connect / OAuth 2.0',
      'Authlete',
      'Auth0',
      'AWS Cognito',
      'SAML',
      'MFA / パスワードポリシー',
    ],
  },
  {
    category: '言語',
    skills: ['TypeScript', 'Go', 'Python'],
  },
  {
    category: 'フレームワーク・ライブラリ',
    skills: ['React', 'Node.js', 'NestJS', 'Hono', 'Astro', 'fp-ts'],
  },
  {
    category: 'クラウド・インフラ',
    skills: ['AWS', 'Cloudflare', 'Terraform'],
  },
  {
    category: 'データベース',
    skills: ['PostgreSQL', 'DynamoDB', 'Databricks'],
  },
  {
    category: '設計・アーキテクチャ',
    skills: [
      'DDD / ヘキサゴナルアーキテクチャ',
      'サービスベースアーキテクチャ',
      'イベント駆動アーキテクチャ',
    ],
  },
  {
    category: 'プラクティス',
    skills: [
      '関数型プログラミング',
      'ADR',
      'ポストモーテム',
      'SLI/SLO設計',
      'イミュータブルドキュメントモデル',
    ],
  },
];

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout
  title="職務経歴書 - kosui"
  ogTitle="職務経歴書"
  ogDescription="岩佐 幸翠（kosui）の職務経歴書。医療プラットフォームの認証・認可基盤および共通基盤の設計・開発を専門とするテックリード。"
>
  <div class="article-paper">
  <!-- 基本情報 -->
  <section class="mb-10">
    <h1 class="text-3xl font-bold mb-6">職務経歴書</h1>
    <table class="w-full text-base">
      <tbody>
        {
          basicInfo.map((item) => (
            <tr class="border-b border-border dark:border-[#2a2a32]">
              <th class="text-left py-2 pr-4 text-sm font-semibold text-accent dark:text-accent-light whitespace-nowrap w-28 align-top">
                {item.label}
              </th>
              <td class="py-2 text-charcoal dark:text-gray-200">
                {item.href ? (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-accent dark:text-accent-light hover:underline"
                  >
                    {item.value}
                  </a>
                ) : (
                  item.value
                )}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </section>

  <!-- 職務要約 -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-4">
      <span class="heading-accent">職務要約</span>
    </h2>
    <p class="text-base text-charcoal dark:text-gray-200 leading-relaxed">
      株式会社カケハシにて、医療プラットフォームの認証・認可基盤および組織管理基盤の設計・開発をリード。OpenID Connect / OAuth 2.0の深い専門性を軸に、テックリード兼PdMとして全社認証基盤の刷新を主導。前職ではタクシー配車アプリのWebエンジニアとしてフロントエンド・バックエンド・インフラを横断的に担当。
    </p>
    <ul class="mt-4 space-y-2">
      <li class="text-base text-charcoal dark:text-gray-200 leading-relaxed flex gap-2">
        <span class="text-accent dark:text-accent-light flex-shrink-0 mt-0.5">-</span>
        <span><strong>全社統一認証基盤の構築</strong>: 技術検証からAuthlete選定、6以上のプロダクトの移行統括までを一貫してリード</span>
      </li>
      <li class="text-base text-charcoal dark:text-gray-200 leading-relaxed flex gap-2">
        <span class="text-accent dark:text-accent-light flex-shrink-0 mt-0.5">-</span>
        <span><strong>組織管理基盤のロードマップ再構築</strong>: 要求分析によりスコープを最適化し、当初予定より4ヶ月前倒しで提供</span>
      </li>
      <li class="text-base text-charcoal dark:text-gray-200 leading-relaxed flex gap-2">
        <span class="text-accent dark:text-accent-light flex-shrink-0 mt-0.5">-</span>
        <span><strong>プラットフォーム戦略の立案</strong>: CTOへの課題提起と3段階ロードマップの策定を主導し、経営層との共通認識を形成</span>
      </li>
    </ul>
  </section>

  <!-- 職務経歴 -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-4">
      <span class="heading-accent">職務経歴</span>
    </h2>
    <div class="space-y-8">
      {
        careers.map((career) => (
          <div>
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-1">
              <h3 class="text-xl font-bold text-charcoal dark:text-gray-100">
                {career.org}
              </h3>
              <span class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap flex-shrink-0 sm:pt-1">
                {career.period}
              </span>
            </div>
            <p class="text-sm text-charcoal dark:text-gray-200 mb-4">
              {career.description}
            </p>

            <div class="space-y-6">
              {career.projects.map((project) => (
                <div>
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-1">
                    <h4 class="text-lg font-bold text-charcoal dark:text-gray-100">
                      {project.title}
                    </h4>
                    <span class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap flex-shrink-0">
                      {project.period}
                    </span>
                  </div>
                  <p class="text-sm font-medium text-accent dark:text-accent-light mb-2">
                    {project.role}
                  </p>
                  <p class="text-base text-charcoal dark:text-gray-200 leading-relaxed mb-3">
                    {project.summary}
                  </p>
                  {project.phases && (
                    <div class="space-y-4 mb-3">
                      {project.phases.map((phase) => (
                        <div>
                          <h5 class="text-base font-semibold text-charcoal dark:text-gray-100 mb-2">
                            {phase.label}
                          </h5>
                          <ul class="space-y-2 pl-1">
                            {phase.items.map((item) => (
                              <li class="text-base text-charcoal dark:text-gray-200 leading-relaxed flex gap-2">
                                <span class="text-accent dark:text-accent-light flex-shrink-0 mt-0.5">
                                  -
                                </span>
                                <span>{item}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  )}
                  {project.achievements && (
                    <ul class="space-y-2 mb-3">
                      {project.achievements.map((achievement) => (
                        <li class="text-base text-charcoal dark:text-gray-200 leading-relaxed flex gap-2">
                          <span class="text-accent dark:text-accent-light flex-shrink-0 mt-0.5">
                            -
                          </span>
                          <span>{achievement}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  <div class="flex flex-wrap gap-1.5">
                    {project.techStack.map((tech) => (
                      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-sm bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-gray-200">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 技術スキル -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-4">
      <span class="heading-accent">技術スキル</span>
    </h2>
    <div class="space-y-4">
      {
        skillCategories.map((cat) => (
          <div class="flex flex-col sm:flex-row sm:gap-4">
            <span
              class="text-sm font-semibold text-accent dark:text-accent-light w-44 flex-shrink-0 pt-0.5"
            >
              {cat.category}
            </span>
            <div class="flex flex-wrap gap-1.5 mt-1 sm:mt-0">
              {
                cat.skills.map((skill) => (
                  <span
                    class="inline-flex items-center rounded-full px-2.5 py-0.5 text-sm bg-tag-bg dark:bg-[#2a2a32] text-charcoal dark:text-[#ececec]"
                  >
                    {skill}
                  </span>
                ))
              }
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 学歴 -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-4">
      <span class="heading-accent">学歴</span>
    </h2>
    <div class="space-y-4">
      {
        education.map((item) => (
          <div class="flex gap-4">
            <span
              class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap pt-0.5 w-40 flex-shrink-0"
            >
              {item.period}
            </span>
            <div>
              <p class="text-base font-semibold text-charcoal dark:text-gray-100">
                {item.org}
              </p>
              <p class="text-sm font-medium text-accent dark:text-accent-light">
                {item.degree}
              </p>
              {
                item.description && (
                  <p class="text-base text-charcoal dark:text-gray-200 mt-0.5 leading-relaxed">
                    {item.description}
                  </p>
                )
              }
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 社外活動 -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-4">
      <span class="heading-accent">社外活動</span>
    </h2>

    <h3 class="text-lg font-bold text-charcoal dark:text-gray-100 mb-3">
      登壇
    </h3>
    <div class="space-y-2 mb-6">
      {
        talks.map((talk) => (
          <a
            href={`/talks/${talk.year}/${talk.name}`}
            class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 border border-border dark:border-[#2a2a32] rounded-xl p-4 hover:bg-tag-bg dark:hover:bg-[#2a2a32] transition-colors"
          >
            <span
              class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap flex-shrink-0"
            >
              {formatDate(talk.date)}
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-base font-semibold text-charcoal dark:text-gray-100 leading-snug">
                {talk.title}
              </p>
              <p class="text-sm text-accent dark:text-accent-light mt-0.5">
                @ {talk.event}
              </p>
            </div>
          </a>
        ))
      }
    </div>

    <h3 class="text-lg font-bold text-charcoal dark:text-gray-100 mb-3">
      執筆
    </h3>
    <div class="space-y-2">
      {
        externalArticles.map((article) => (
          <a
            href={article.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 border border-border dark:border-[#2a2a32] rounded-xl p-4 hover:bg-tag-bg dark:hover:bg-[#2a2a32] transition-colors"
          >
            <span
              class="text-sm text-charcoal dark:text-gray-200 whitespace-nowrap flex-shrink-0"
            >
              {formatDate(article.date)}
            </span>
            <div class="flex-1 min-w-0">
              <p class="text-base font-semibold text-charcoal dark:text-gray-100 leading-snug">
                {article.title}
              </p>
              <p class="text-sm text-accent dark:text-accent-light mt-0.5">
                @ {article.publisher}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
  </div>
</BaseLayout>
