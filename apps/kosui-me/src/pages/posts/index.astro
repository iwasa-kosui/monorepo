---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection } from 'astro:content';

type PostEntry = CollectionEntry<'posts'>;

const posts: PostEntry[] = await getCollection('posts');
const sortedPosts: PostEntry[] = posts.sort(
  (a: PostEntry, b: PostEntry) =>
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}
---

<BaseLayout title="Posts - kosui" ogTitle="Posts">
  <h1 class="text-3xl font-bold mb-8">Posts</h1>
  <ul class="space-y-4">
    {
      sortedPosts.map((post) => (
        <li>
          <a
            href={`/${post.data.slug}`}
            class="block bg-cream dark:bg-[#2A2630] rounded-clay shadow-clay dark:shadow-clay-dark p-6 clay-hover-lift hover:shadow-clay-hover dark:hover:shadow-clay-dark-hover"
          >
            <time
              class="text-xs text-terracotta dark:text-terracotta-light"
              datetime={post.data.date}
            >
              {formatDate(post.data.date)}
            </time>
            <h2 class="text-lg font-semibold text-charcoal dark:text-gray-100 mt-1">
              {post.data.title}
            </h2>
            {
              post.data.description && (
                <p class="mt-1 text-sm text-charcoal-light dark:text-warm-gray">
                  {post.data.description}
                </p>
              )
            }
            {
              post.data.tags && post.data.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {
                    post.data.tags.map((tag: string) => (
                      <span
                        class="inline-block px-2 py-0.5 text-xs rounded-full bg-sand-light dark:bg-[#3A3540] text-charcoal-light dark:text-warm-gray"
                      >
                        {tag}
                      </span>
                    ))
                  }
                </div>
              )
            }
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
