---
import AuthorCard from '@/components/AuthorCard.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection, render } from 'astro:content';

type PostEntry = CollectionEntry<'posts'>;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post: PostEntry) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: PostEntry };
const { Content } = await render(post);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

const slugFileName = post.data.slug.replace(/\//g, '-');
const ogImage = `https://kosui.me/og/${slugFileName}.png`;
const pageUrl = `https://kosui.me/${post.data.slug}`;
---

<BaseLayout
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage={ogImage}
  ogUrl={pageUrl}
  ogType="article"
>
  <article class="article-paper">
    <header class="mb-8">
      <time
        class="text-sm text-accent dark:text-accent-light"
        datetime={post.data.date}
      >
        {formatDate(post.data.date)}
      </time>
      <h1
        class="text-3xl font-bold mt-2 mb-4"
        transition:name={`post-title-${post.data.slug}`}
      >
        {post.data.title}
      </h1>
      <AuthorCard />
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>

  <section class="mt-12 mb-8">
    <h3 class="text-sm font-medium text-charcoal dark:text-gray-100 mb-3 text-center">
      Share
    </h3>
    <ShareButtons title={post.data.title} url={pageUrl} />
  </section>

  <section class="p-4 bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark">
    <AuthorCard />
  </section>

  <script>
  document.addEventListener('astro:page-load', async () => {
    const mermaidElements = document.querySelectorAll<HTMLPreElement>(
      'pre.mermaid',
    );
    if (mermaidElements.length > 0) {
      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({ startOnLoad: false, theme: 'dark' });
      await mermaid.run({ nodes: mermaidElements });
    }
  });
  </script>
</BaseLayout>
