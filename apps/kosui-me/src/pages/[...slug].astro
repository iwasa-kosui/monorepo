---
import AuthorCard from '@/components/AuthorCard.astro';
import RelatedArticles from '@/components/RelatedArticles.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import ThemeHubLinks from '@/components/ThemeHubLinks.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { type CollectionEntry, getCollection, render } from 'astro:content';

type PostEntry = CollectionEntry<'posts'>;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post: PostEntry) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: PostEntry };
const { Content } = await render(post);
const isPrivate = post.data.private === true;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
}

const slugFileName = post.data.slug.replace(/\//g, '-');
const ogImage = `https://kosui.me/og/${slugFileName}.png`;
const pageUrl = `https://kosui.me/${post.data.slug}`;
---

<BaseLayout
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage={ogImage}
  ogUrl={pageUrl}
  ogType="article"
  noindex={isPrivate}
>
  <article class="article-paper">
    <header class="mb-8">
      <time
        class="text-sm text-accent dark:text-accent-light"
        datetime={post.data.date}
      >
        {formatDate(post.data.date)}
      </time>
      <h1
        class="text-3xl font-bold mt-2 mb-4"
        transition:name={`post-title-${post.data.slug}`}
      >
        {post.data.title}
      </h1>
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <AuthorCard compact />
        {!isPrivate && <ShareButtons title={post.data.title} url={pageUrl} />}
      </div>
    </header>
    {
      isPrivate && (
        <div class="mb-6 px-4 py-3 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-700/50 rounded-clay shadow-clay dark:shadow-clay-dark">
          <p class="text-sm text-amber-800 dark:text-amber-200">
            この記事は限定公開です。検索エンジンやRSSフィードには掲載されません。
          </p>
        </div>
      )
    }
    <div class="prose">
      <Content />
    </div>
    {
      !isPrivate && (
        <section class="mt-12">
          <ShareButtons title={post.data.title} url={pageUrl} />
        </section>
      )
    }
  </article>

  {
    !isPrivate && post.data.themes && post.data.themes.length > 0
      && (
      <section class="mt-8 mb-8">
        <ThemeHubLinks themes={post.data.themes} />
      </section>
    )
  }

  {
    !isPrivate && post.data.themes && post.data.themes.length > 0
      && (
      <RelatedArticles currentSlug={post.data.slug} themes={post.data.themes} />
    )
  }

  <section class="p-4 bg-card dark:bg-[#1c1c22] rounded-clay shadow-clay dark:shadow-clay-dark">
    <AuthorCard />
  </section>

  <script>
  document.addEventListener('astro:page-load', async () => {
    const mermaidElements = document.querySelectorAll<HTMLPreElement>(
      'pre.mermaid',
    );
    if (mermaidElements.length > 0) {
      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({ startOnLoad: false, theme: 'neutral' });
      await mermaid.run({ nodes: mermaidElements });
    }
  });
  </script>
</BaseLayout>
