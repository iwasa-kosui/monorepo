---
import { getTagDefinition } from '@/config/tags';

interface Props {
  tag: string;
  linked?: boolean;
  size?: 'sm' | 'md';
}

const { tag, linked = true, size = 'sm' } = Astro.props;
const { color } = getTagDefinition(tag);

const sizeClasses = size === 'md' ? 'px-3 py-1 text-sm' : 'px-2 py-0.5 text-xs';
const dotSize = size === 'md' ? 'w-2.5 h-2.5' : 'w-2 h-2';
---

{
  linked ? (
    <a
      href={`/tags/${tag}`}
      class:list={[
        'inline-flex items-center gap-1.5 rounded-full bg-tag-bg dark:bg-[#2a2a32] text-subtle dark:text-[#9ca3af] hover:bg-accent/10 dark:hover:bg-accent/20 transition-colors',
        sizeClasses,
      ]}
    >
      <span
        class:list={['rounded-full flex-shrink-0', dotSize]}
        style={`background-color: ${color}`}
      />
      {tag}
    </a>
  ) : (
    <span
      class:list={[
        'inline-flex items-center gap-1.5 rounded-full bg-tag-bg dark:bg-[#2a2a32] text-subtle dark:text-[#9ca3af]',
        sizeClasses,
      ]}
    >
      <span
        class:list={['rounded-full flex-shrink-0', dotSize]}
        style={`background-color: ${color}`}
      />
      {tag}
    </span>
  )
}
