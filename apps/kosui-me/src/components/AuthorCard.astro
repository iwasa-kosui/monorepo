---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class="flex items-center gap-4">
  <img
    src="https://icon.kosui.me"
    alt="kosui"
    width="48"
    height="48"
    class="rounded-full ring-2 ring-accent/20 flex-shrink-0"
  />
  <div class="min-w-0">
    <div class="flex items-baseline gap-2">
      <span class="font-bold text-charcoal dark:text-gray-100">岩佐 幸翠</span>
      <span class="text-sm text-subtle dark:text-[#9ca3af]">/ kosui</span>
    </div>
    <p class="text-sm text-accent dark:text-accent-light font-medium">
      テックリード @ 株式会社カケハシ
    </p>
    {
      !compact && (
        <p class="text-xs text-subtle dark:text-[#9ca3af] mt-1 leading-relaxed">
          医療SaaSの共通基盤を開発。TypeScriptと関数型プログラミングで堅牢なシステム設計を実践。
        </p>
      )
    }
  </div>
</div>
