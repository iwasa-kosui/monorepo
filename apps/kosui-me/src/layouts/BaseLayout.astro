---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { SearchModal } from '@/components/SearchModal/SearchModal';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogUrl?: string;
  ogType?: string;
  oembedUrl?: string;
  noindex?: boolean;
}

const {
  title = 'kosui',
  description =
    'kosuiの技術ブログ。TypeScript, Node.js, インフラなどの知見を発信しています。',
  ogTitle,
  ogDescription,
  ogImage = 'https://kosui.me/og/default.png',
  ogUrl,
  ogType = 'website',
  oembedUrl,
  noindex = false,
} = Astro.props;

const displayTitle = ogTitle ? `${ogTitle} - kosui` : title;
const displayOgTitle = ogTitle ?? title;
const displayOgDescription = ogDescription ?? description;
const canonicalUrl = ogUrl ?? new URL(Astro.url.pathname, Astro.site).href;

const slideUpFade = {
  forwards: {
    old: {
      name: 'slideUpFadeOut',
      duration: '200ms',
      easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
      fillMode: 'both' as const,
    },
    new: {
      name: 'slideUpFadeIn',
      duration: '300ms',
      delay: '100ms',
      easing: 'cubic-bezier(0.0, 0, 0.2, 1)',
      fillMode: 'both' as const,
    },
  },
  backwards: {
    old: {
      name: 'slideDownFadeOut',
      duration: '200ms',
      easing: 'cubic-bezier(0.4, 0, 0.2, 1)',
      fillMode: 'both' as const,
    },
    new: {
      name: 'slideDownFadeIn',
      duration: '300ms',
      delay: '100ms',
      easing: 'cubic-bezier(0.0, 0, 0.2, 1)',
      fillMode: 'both' as const,
    },
  },
};

const pathname = Astro.url.pathname;

const navItems = [
  {
    href: '/',
    label: 'Posts',
    isActive: pathname === '/' || pathname.startsWith('/posts'),
  },
  {
    href: '/talks',
    label: 'Talks',
    isActive: pathname.startsWith('/talks'),
  },
  {
    href: '/about',
    label: 'About',
    isActive: pathname.startsWith('/about'),
  },
  { href: '/feed.xml', label: 'RSS', isActive: false, external: true },
] as const;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, viewport-fit=cover"
    />
    <meta name="color-scheme" content="light dark" />
    <title>{displayTitle}</title>
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="description" content={displayOgDescription} />
    <meta property="og:title" content={displayOgTitle} />
    <meta property="og:description" content={displayOgDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="kosui" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <link rel="canonical" href={canonicalUrl} />
    {ogUrl && <meta property="og:url" content={ogUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={displayOgTitle} />
    <meta name="twitter:description" content={displayOgDescription} />
    <meta name="twitter:image" content={ogImage} />
    {
      oembedUrl && (
        <link
          rel="alternate"
          type="application/json+oembed"
          href={oembedUrl}
          title={displayOgTitle}
        />
      )
    }
    <link
      rel="alternate"
      type="application/rss+xml"
      title="kosui"
      href="/feed.xml"
    />
    <ClientRouter />
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <header transition:name="site-header">
        <nav class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-between">
          <a
            href="/"
            class="flex items-center gap-2 sm:gap-3 text-2xl font-bold text-accent hover:text-accent-dark transition-colors"
          >
            <img
              src="https://icon.kosui.me"
              alt=""
              width="40"
              height="40"
              class="rounded-full"
              transition:name={pathname !== '/' ? 'site-logo' : undefined}
            />
            <span class="hidden sm:inline">kosui</span>
          </a>
          <div class="hidden md:flex gap-0.5 sm:gap-1 text-xs sm:text-sm">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class={item.isActive
                  ? 'px-2 sm:px-3 py-1.5 rounded-full bg-accent text-white font-semibold transition-colors'
                  : 'px-2 sm:px-3 py-1.5 rounded-full text-subtle dark:text-[#9ca3af] hover:text-charcoal dark:hover:text-[#ececec] transition-colors'}
                  {...('external' in item
                  ? {
                    target: '_blank',
                    rel: 'noopener noreferrer',
                  }
                  : {})}
                >
                  {item.label}
                </a>
              ))
            }
          </div>
          <button
            type="button"
            class="hidden md:inline-flex items-center gap-1 px-2 sm:px-3 py-1.5 rounded-full text-subtle dark:text-[#9ca3af] hover:text-charcoal dark:hover:text-[#ececec] transition-colors"
            aria-label="検索を開く"
            data-search-trigger
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </nav>
      </header>
      <main
        class="flex-1 max-w-3xl mx-auto px-4 py-8 pb-20 md:pb-8 w-full"
        transition:animate={slideUpFade}
      >
        <slot />
      </main>
      <footer>
        <div class="max-w-3xl mx-auto px-4 py-6 text-center text-sm text-subtle dark:text-[#9ca3af]">
          &copy; {new Date().getFullYear()} kosui
          <span class="mx-1">&middot;</span>
          <a
            href="/privacy"
            class="hover:text-accent dark:hover:text-accent-light transition-colors"
          >Privacy Policy</a>
        </div>
      </footer>
    </div>
    <nav
      class="fixed bottom-0 inset-x-0 bg-bg/80 dark:bg-[#111114]/80 backdrop-blur border-t border-border dark:border-[#2a2a32] md:hidden bottom-nav"
      aria-label="Mobile navigation"
      transition:name="mobile-nav"
    >
      <div class="flex items-center justify-around max-w-3xl mx-auto px-4 py-2">
        {
          navItems.filter(item => !('external' in item)).map((
              item,
            ) => (
            <a
              href={item.href}
              class={`flex flex-col items-center gap-0.5 py-1 px-3 text-[10px] transition-all ${
                item.isActive
                  ? 'text-accent font-semibold scale-110'
                  : 'text-subtle dark:text-[#9ca3af] active:scale-95'
              }`}
            >
              {
                item.label === 'Posts' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                    <polyline points="14 2 14 8 20 8" />
                    <line x1="16" y1="13" x2="8" y2="13" />
                    <line x1="16" y1="17" x2="8" y2="17" />
                    <polyline points="10 9 9 9 8 9" />
                  </svg>
                )
              }
              {
                item.label === 'Talks' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
                    <line x1="12" y1="19" x2="12" y2="23" />
                    <line x1="8" y1="23" x2="16" y2="23" />
                  </svg>
                )
              }
              {
                item.label === 'About' && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                  </svg>
                )
              }
              <span>{item.label}</span>
            </a>
          ))
        }
        <button
          type="button"
          class="flex flex-col items-center gap-0.5 py-1 px-3 text-[10px] transition-all text-subtle dark:text-[#9ca3af] active:scale-95"
          aria-label="検索を開く"
          data-search-trigger
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <span>Search</span>
        </button>
      </div>
    </nav>
    <script>
    document.addEventListener('astro:page-load', () => {
        const prefersReduced =
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReduced) return;

        const cards = document.querySelectorAll<HTMLElement>(
          '.clay-hover-lift',
        );
        cards.forEach((card, index) => {
          if (index >= 15) {
            card.style.opacity = '1';
            return;
          }
          card.classList.add('animate-card-entrance');
          card.style.animationDelay = `${index * 60}ms`;
        });

        document.querySelectorAll<HTMLElement>('.heading-accent').forEach(
          (el) => {
            el.style.animationName = 'none';
            void el.offsetWidth;
            el.style.animationName = '';
          },
        );

        document.querySelectorAll<HTMLElement>('main > section').forEach(
          (section, index) => {
            section.classList.add('animate-section-entrance');
            section.style.animationDelay = `${150 + index * 100}ms`;
          },
        );

        document.querySelectorAll('[data-search-trigger]').forEach(
          (btn) => {
            btn.addEventListener('click', () => {
              document.dispatchEvent(new CustomEvent('open-search'));
            });
          },
        );
      });
    </script>
    <SearchModal client:idle />
  </body>
</html>
