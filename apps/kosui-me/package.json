{
  "name": "kosui-me",
  "type": "module",
  "private": true,
  "engines": {
    "node": "24.12.0"
  },
  "dependencies": {
    "mermaid": "11.12.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "6.30.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@mdx-js/rollup": "3.1.0",
    "@resvg/resvg-js": "2.6.2",
    "@shikijs/rehype": "3.7.0",
    "@tailwindcss/vite": "4.1.11",
    "@types/node": "24.10.4",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "dprint": "0.51.1",
    "eslint": "^9.36.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "feed": "4.2.2",
    "remark-frontmatter": "5.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx-frontmatter": "5.0.0",
    "satori": "0.19.1",
    "tailwindcss": "4.1.11",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.0",
    "vite": "7.3.1",
    "vitest": "3.1.2",
    "wrangler": "4.20.0"
  },
  "scripts": {
    "dev": "vite",
    "generate:og": "npx tsx scripts/generate-og-images.ts",
    "generate:feed": "npx tsx scripts/generate-feed.ts",
    "prebuild": "pnpm generate:og && pnpm generate:feed",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest --run",
    "typecheck": "tsc",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "deploy": "wrangler pages deploy dist"
  }
}
