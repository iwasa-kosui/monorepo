{
  "name": "kosui-me",
  "type": "module",
  "private": true,
  "engines": {
    "node": "24.12.0"
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/mdx": "4.3.13",
    "@astrojs/react": "4.4.2",
    "@astrojs/sitemap": "3.7.0",
    "astro": "^5.16.15",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/vite": "4.1.11",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.10.4",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "dprint": "0.51.1",
    "eslint": "^9.36.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "feed": "4.2.2",
    "js-yaml": "4.1.0",
    "open-graph-scraper": "6.11.0",
    "satori": "0.19.1",
    "sharp": "0.34.5",
    "tailwindcss": "4.1.11",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.0",
    "vitest": "3.1.2",
    "wrangler": "4.20.0"
  },
  "scripts": {
    "dev": "astro dev",
    "generate:og": "npx tsx scripts/generate-og-images.ts",
    "generate:og:talks": "node scripts/generate-og-images-talks.mjs",
    "generate:talks": "npx tsx scripts/generate-talks.ts",
    "fetch:ogp": "node scripts/fetch-ogp.mjs",
    "prebuild": "pnpm generate:og && pnpm generate:og:talks && pnpm fetch:ogp && pnpm generate:talks",
    "build": "astro build && node scripts/build-slidev.mjs",
    "preview": "astro preview",
    "test": "vitest",
    "test:ci": "vitest --run",
    "tsc": "astro check",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "deploy": "wrangler pages deploy dist"
  }
}
