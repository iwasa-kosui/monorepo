{
  "name": "@iwasa-kosui/slack-thread-expander",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.12.0"
  },
  "dependencies": {
    "@iwasa-kosui/result": "workspace:*",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@google/clasp": "2.5.0",
    "@types/google-apps-script": "1.0.99",
    "@types/node": "24.10.4",
    "dprint": "0.51.1",
    "esbuild": "0.27.2",
    "eslint": "^9.36.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.0",
    "vitest": "3.1.2"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "tsc": "tsc --noEmit",
    "lint:fix": "eslint --fix .",
    "format": "dprint fmt",
    "test": "vitest run",
    "test:ci": "vitest run",
    "clasp:push": "clasp push -f",
    "deploy": "pnpm build && pnpm clasp:push"
  }
}
